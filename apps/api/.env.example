DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medora?schema=public"
PORT=3001

# Origines additionnelles CORS (séparées par des virgules). Par défaut : http://localhost:3002 et :3003
# CORS_ORIGINS=http://127.0.0.1:3003

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
# Durée de vie du jeton d’accès (aligner apps/web JWT_ACCESS_TTL pour les cookies). Recommandé prod : 8h.
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=14d
TOKEN_ISSUER=medora-s

# Base URL for password reset links (use your web app URL, e.g. http://localhost:3002). In dev the link is also logged to API console.
RESET_PASSWORD_BASE_URL=http://localhost:3002
