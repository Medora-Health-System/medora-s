generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  ADMIN
  PROVIDER
  RN
  FRONT_DESK
  LAB
  RADIOLOGY
  PHARMACY
  BILLING
}

enum DepartmentCode {
  PRIMARY_CARE
  LAB
  RAD
  PHARM
  INPATIENT
}

enum SexAtBirth {
  M
  F
  X
  U
}

enum PathwayType {
  STROKE
  SEPSIS
  STEMI
  TRAUMA
}

enum PathwayStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum PathwayMilestoneStatus {
  PENDING
  MET
  OVERDUE
  SKIPPED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  VIEW
  SEED
  PATIENT_CREATE
  PATIENT_UPDATE
  PATIENT_VIEW
  ENCOUNTER_CREATE
  ENCOUNTER_UPDATE
  ENCOUNTER_CLOSE
  ENCOUNTER_VIEW
  ORDER_CREATE
  ORDER_CANCEL
  ORDER_VIEW
  CHART_ACCESS
  ORDER_UPDATE
  RESULT_UPLOAD
  MEDICATION_DISPENSED
  BILLING_FINALIZED
  CHART_OPEN
  TRIAGE_SAVE
  ORDER_ACK
  ORDER_START
  ORDER_COMPLETE
  RESULT_VERIFY
  CRITICAL_FLAG
  PATHWAY_ACTIVATED
  ORDERS_CREATED
}

enum EncounterType {
  OUTPATIENT
  INPATIENT
  EMERGENCY
  URGENT_CARE
}

enum EncounterStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum DischargeStatus {
  DISCHARGED
  AMA
  TRANSFERRED
  DECEASED
}

enum OrderStatus {
  DRAFT
  PLACED
  ACKNOWLEDGED
  IN_PROGRESS
  COMPLETED
  RESULTED
  VERIFIED
  CANCELLED
  PENDING
  SIGNED
}

enum OrderPriority {
  ROUTINE
  URGENT
  STAT
}

model Facility {
  id        String      @id @default(uuid())
  code      String      @unique
  name      String
  country   String
  timezone  String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  departments       Department[]
  userRoles         UserRole[]
  patientsRegistered Patient[]  @relation("RegisteredAtFacility")
  patients          Patient[]   @relation("PatientFacility")
  encounters        Encounter[]
  orders            Order[]
  auditLogs         AuditLog[]
  triages           Triage[]
  results           Result[]
  pathwaySessions   PathwaySession[]
  protocolOrderSets ProtocolOrderSet[]
}

model Department {
  id         String         @id @default(uuid())
  facilityId String
  code       DepartmentCode
  name       String
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  facility  Facility @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  userRoles UserRole[]

  @@unique([facilityId, code])
}

model Role {
  id        String    @id @default(uuid())
  code      RoleCode  @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userRoles UserRole[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  firstName    String
  lastName     String
  passwordHash String
  refreshTokenHash String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userRoles UserRole[]
  auditLogs AuditLog[]
}

model UserRole {
  id           String     @id @default(uuid())
  userId       String
  roleId       String
  facilityId   String
  departmentId String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  facility   Facility   @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([facilityId])
  @@index([departmentId])
  @@unique([userId, roleId, facilityId])
}

model Patient {
  id                     String      @id @default(uuid())
  facilityId             String
  mrn                    String?
  globalMrn              String      @unique
  firstName              String
  lastName               String
  dob                    DateTime?
  phone                  String?
  email                  String?
  sexAtBirth             SexAtBirth?
  nationalId             String?
  address                String?
  city                   String?
  country                String?
  language               String?
  registeredAtFacilityId String
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  facility               Facility    @relation("PatientFacility", fields: [facilityId], references: [id], onDelete: Restrict)
  registeredAtFacility   Facility    @relation("RegisteredAtFacility", fields: [registeredAtFacilityId], references: [id], onDelete: Restrict)
  encounters             Encounter[]
  orders                 Order[]
  auditLogs              AuditLog[]

  @@index([facilityId])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([mrn])
  @@unique([facilityId, mrn])
}

model AuditLog {
  id         String      @id @default(uuid())
  createdAt  DateTime    @default(now())
  userId     String?
  facilityId String?
  patientId  String?
  ip         String?
  userAgent  String?
  entityType String
  entityId   String?
  action     AuditAction
  metadata   Json?

  user     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  facility Facility?   @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  patient  Patient?    @relation(fields: [patientId], references: [id], onDelete: SetNull)
  encounter Encounter? @relation("EncounterAuditLogs", fields: [encounterId], references: [id], onDelete: SetNull)
  order    Order?      @relation("OrderAuditLogs", fields: [orderId], references: [id], onDelete: SetNull)
  encounterId String?
  orderId    String?

  @@index([userId])
  @@index([facilityId])
  @@index([createdAt])
  @@index([encounterId])
}

model Encounter {
  id            String          @id @default(uuid())
  facilityId    String
  patientId     String
  providerId    String?
  type          EncounterType
  status        EncounterStatus @default(OPEN)

  chiefComplaint String?
  triageAcuity   Int?
  vitals         Json?
  nursingAssessment Json?
  providerNote   String?
  disposition    String?
  dischargeStatus DischargeStatus?
  dischargedAt   DateTime?

  notes         String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  patient       Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  facility      Facility        @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  orders        Order[]
  auditLogs     AuditLog[]      @relation("EncounterAuditLogs")
  triage        Triage?
  pathwaySession PathwaySession?

  @@index([facilityId])
  @@index([patientId])
  @@index([status])
}

model Order {
  id          String      @id @default(uuid())
  encounterId String
  facilityId  String
  type        String      // "LAB", "IMAGING", "MEDICATION"
  status      OrderStatus @default(PENDING)
  priority    OrderPriority @default(ROUTINE)
  notes       String?
  orderedBy   String?
  source      String?     // "MANUAL", "PROTOCOL"
  pathwaySessionId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  encounter   Encounter   @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  facility    Facility    @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  patientId   String
  pathwaySession PathwaySession? @relation(fields: [pathwaySessionId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  auditLogs   AuditLog[]  @relation("OrderAuditLogs")

  @@index([encounterId])
  @@index([facilityId])
  @@index([patientId])
  @@index([status])
  @@index([pathwaySessionId])
}

model OrderItem {
  id              String      @id @default(uuid())
  orderId         String
  catalogItemId   String
  catalogItemType String      // "LAB_TEST", "IMAGING_STUDY", "MEDICATION"
  quantity        Int?
  notes           String?
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  result          Result?

  @@index([orderId])
  @@index([status])
  @@index([catalogItemType])
}

model Triage {
  id              String    @id @default(uuid())
  encounterId     String    @unique
  facilityId      String
  chiefComplaint  String?
  onsetAt         DateTime?
  esi             Int?
  vitalsJson      Json?
  strokeScreen    Json?
  sepsisScreen    Json?
  triageCompleteAt DateTime?
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  encounter       Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  facility        Facility  @relation(fields: [facilityId], references: [id], onDelete: Restrict)

  @@index([facilityId])
  @@index([encounterId])
}

model Result {
  id                      String    @id @default(uuid())
  orderItemId             String    @unique
  facilityId              String
  resultData              Json?
  resultText              String?
  criticalValue           Boolean   @default(false)
  verifiedByUserId        String?
  verifiedAt              DateTime?
  acknowledgedByProviderAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  orderItem               OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  facility                Facility  @relation(fields: [facilityId], references: [id], onDelete: Restrict)

  @@index([facilityId])
  @@index([orderItemId])
  @@index([criticalValue])
}

model CatalogLabTest {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CatalogImagingStudy {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CatalogMedication {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PathwaySession {
  id          String          @id @default(uuid())
  encounterId String          @unique
  facilityId  String
  type        PathwayType
  status      PathwayStatus  @default(ACTIVE)
  contextJson Json?
  activatedAt DateTime        @default(now())
  pausedAt    DateTime?
  completedAt DateTime?
  activatedBy String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  encounter   Encounter       @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  facility    Facility        @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  milestones  PathwayMilestone[]
  orders      Order[]

  @@index([encounterId])
  @@index([facilityId])
  @@index([type])
  @@index([status])
  @@map("PathwaySession")
}

model PathwayMilestone {
  id          String                  @id @default(uuid())
  pathwaySessionId String
  name        String
  description String?
  targetMinutes Int                   // Target time in minutes from activation
  status      PathwayMilestoneStatus  @default(PENDING)
  metAt       DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  pathwaySession PathwaySession @relation(fields: [pathwaySessionId], references: [id], onDelete: Cascade)

  @@index([pathwaySessionId])
  @@index([status])
  @@map("PathwayMilestone")
}

model ProtocolOrderSet {
  id          String      @id @default(uuid())
  facilityId  String
  pathwayType PathwayType
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  facility    Facility    @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  items       ProtocolOrderSetItem[]

  @@unique([facilityId, pathwayType])
  @@index([facilityId])
  @@index([pathwayType])
  @@index([isActive])
  @@map("ProtocolOrderSet")
}

model ProtocolOrderSetItem {
  id                  String      @id @default(uuid())
  protocolOrderSetId  String
  catalogLabTestId    String?
  catalogImagingStudyId String?
  catalogMedicationId String?
  priority            OrderPriority @default(ROUTINE)
  sequence            Int         // Order within the set
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  protocolOrderSet    ProtocolOrderSet @relation(fields: [protocolOrderSetId], references: [id], onDelete: Cascade)

  @@index([protocolOrderSetId])
  @@index([sequence])
  @@map("ProtocolOrderSetItem")
}

