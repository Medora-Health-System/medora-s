# URL de l’API Nest (proxy Next → API)
API_URL=http://localhost:3001

# Durée du jeton d’accès — DOIT être la même valeur que JWT_ACCESS_TTL dans apps/api/.env (Nest).
# Utilisée par les routes Next pour maxAge des cookies d’accès et pour accessTokenTtlSeconds (GET /api/auth/me),
# ce qui pilote le rafraîchissement proactif de session dans l’interface (sans dépendre d’un TTL « supposé » dans le bundle).
JWT_ACCESS_TTL=8h

# Optionnel : repli uniquement si le client ne reçoit pas accessTokenTtlSeconds (ex. vieux déploiement).
# Si défini, doit rester identique à JWT_ACCESS_TTL ci-dessus et à l’API — sinon dérive possible avant cette correction.
# NEXT_PUBLIC_JWT_ACCESS_TTL=8h
