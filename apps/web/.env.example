# URL de l’API Nest (proxy Next → API)
API_URL=http://localhost:3001

# Durée du jeton d’accès — doit correspondre à JWT_ACCESS_TTL côté apps/api (cookies de session).
JWT_ACCESS_TTL=8h

# Même valeur que JWT_ACCESS_TTL de l’API (injectée au build). Utilisée par le client pour l’intervalle de refresh proactif.
NEXT_PUBLIC_JWT_ACCESS_TTL=8h
