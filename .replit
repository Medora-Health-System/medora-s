modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "dev-secret-key-change-in-production"
NEXT_PUBLIC_API_BASE_URL = "http://localhost:3001"
JWT_ACCESS_SECRET = "dev-access-secret-change-in-production-12345"
JWT_REFRESH_SECRET = "dev-refresh-secret-change-in-production-67890"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:api & npm run dev:web & wait"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd apps/api && npm run start & cd apps/web && npm run start"]
build = ["bash", "-c", "npm install && cd packages/shared && npm run build && cd ../../apps/api && npm run build && cd ../web && npm run build"]
