{
  "name": "medora-s",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "verify": "bash scripts/verify-stability.sh",
    "verify:shared": "pnpm --filter @medora/shared build",
    "verify:web": "pnpm --filter @medora/web exec tsc --noEmit",
    "verify:api": "pnpm --filter @medora/api exec tsc --noEmit -p tsconfig.build.json",
    "db:clear:patients": "pnpm --filter @medora/api run db:clear:patients",
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev --workspace=@medora/web",
    "dev:api": "npm run dev --workspace=@medora/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}

